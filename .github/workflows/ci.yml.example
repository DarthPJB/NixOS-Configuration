# Example GitHub Actions CI/CD Workflow for NixOS Configuration
# This file is generated by: nix run .#generate-ci-workflow
# Do not edit manually - changes will be overwritten

name: NixOS CI/CD

on:
  push:
    branches: [ main, jb/ai/overlord-8 ]
    paths:
      - '**.nix'
      - 'flake.lock'
      - '.github/workflows/**'
  pull_request:
    branches: [ main ]
    paths:
      - '**.nix'
      - 'flake.lock'
  workflow_dispatch:
    inputs:
      machine:
        description: 'Machine to deploy'
        required: true
        type: choice
        options:
          - terminal-zero
          - terminal-nx-01
          - cortex-alpha
          - local-nas
          - alpha-one
          - alpha-two
          - alpha-three
          - LINDA
          - gaming-host-1
          - remote-worker
          - storage-array
          - remote-builder
          - display-0
          - display-1
          - display-2
          - print-controller
      action:
        description: 'Action to perform'
        required: true
        type: choice
        options:
          - build
          - test
          - deploy
        default: 'build'

permissions:
  contents: read
  deployments: write

jobs:
  # Validation and linting
  validation:
    name: Validation & Linting
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Install Nix
        uses: DeterminateSystems/nix-installer-action@main

      - name: Setup Magic Nix Cache
        uses: DeterminateSystems/magic-nix-cache-action@main

      - name: Format check
        run: nix fmt -- --check .

      - name: Flake check
        run: nix flake check

      - name: Dead code check
        run: nix run .#deadnix

  # Build x86_64 configurations
  build-x86:
    name: Build x86_64 - ${{ matrix.machine }}
    runs-on: ubuntu-latest
    needs: validation
    strategy:
      fail-fast: false
      matrix:
        machine:
          - terminal-zero
          - terminal-nx-01
          - cortex-alpha
          - local-nas
          - alpha-one
          - alpha-two
          - alpha-three
          - LINDA
          - gaming-host-1
          - remote-worker
          - storage-array
          - remote-builder
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Install Nix
        uses: DeterminateSystems/nix-installer-action@main

      - name: Setup Magic Nix Cache
        uses: DeterminateSystems/magic-nix-cache-action@main

      - name: Build configuration
        run: nixos-rebuild build --flake .#${{ matrix.machine }}

      - name: Upload build artifact
        uses: actions/upload-artifact@v4
        with:
          name: ${{ matrix.machine }}-config
          path: result/
          retention-days: 7

  # Build ARM configurations
  build-arm:
    name: Build ARM - ${{ matrix.machine }}
    runs-on: ubuntu-latest
    needs: validation
    strategy:
      fail-fast: false
      matrix:
        machine:
          - display-0
          - display-1
          - display-2
          - print-controller
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Install Nix
        uses: DeterminateSystems/nix-installer-action@main

      - name: Setup Magic Nix Cache
        uses: DeterminateSystems/magic-nix-cache-action@main

      - name: Build configuration
        run: nixos-rebuild build --flake .#${{ matrix.machine }}

      - name: Upload build artifact
        uses: actions/upload-artifact@v4
        with:
          name: ${{ matrix.machine }}-config
          path: result/
          retention-days: 7

  # Security scanning
  security:
    name: Security Scan
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Install Nix
        uses: DeterminateSystems/nix-installer-action@main

      - name: Check for secrets
        run: |
          echo "Checking for potential secrets in code..."
          if grep -r "password\|secret\|key\|token" --include="*.nix" . | grep -v "secrix\|public\|pub\|README\|documentation"; then
            echo "⚠️  Potential secrets found in Nix files"
            exit 1
          fi
          echo "✅ No secrets found in Nix files"

      - name: Validate secrix configuration
        run: nix run .#secrix -- --help

  # Manual deployment job
  deploy:
    name: Deploy - ${{ github.event.inputs.machine }}
    runs-on: ubuntu-latest
    needs: [validation, build-x86, build-arm]
    if: github.event_name == 'workflow_dispatch'
    environment: production
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Install Nix
        uses: DeterminateSystems/nix-installer-action@main

      - name: Setup Magic Nix Cache
        uses: DeterminateSystems/magic-nix-cache-action@main

      - name: Build configuration
        run: nixos-rebuild build --flake .#${{ github.event.inputs.machine }}

      - name: Deploy to machine
        if: github.event.inputs.action == 'deploy'
        run: |
          echo "Deploying to ${{ github.event.inputs.machine }}..."
          # Note: Actual deployment requires VPN access and secrets
          # This is a placeholder for the deployment command
          echo "nix run .#${{ github.event.inputs.machine }} -- switch"
          echo "⚠️  Manual deployment required - connect via VPN first"

      - name: Test deployment
        if: github.event.inputs.action == 'test'
        run: |
          echo "Testing deployment to ${{ github.event.inputs.machine }}..."
          echo "nix run .#${{ github.event.inputs.machine }}"
          echo "⚠️  Manual testing required - connect via VPN first"